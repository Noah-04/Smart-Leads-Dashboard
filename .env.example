# Docker Compose ports
FRONTEND_PORT=5173
BACKEND_PORT=5000
MONGO_PORT=27017

# Backend runtime
NODE_ENV=production
PORT=5000
MONGODB_URI=mongodb://mongo:27017/smart-leads-dashboard
JWT_ACCESS_SECRET=replace-with-a-long-random-access-secret
JWT_ACCESS_EXPIRES_IN=15m

# Frontend build-time API base.
# Use /api/v1 for Docker because nginx proxies /api to the backend service.
VITE_API_BASE_URL=/api/v1

# Seeded admin login:
# Email: admin@company.com
# Password: Admin@123
